<Window x:Class="PrismUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:PrismUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="400" d:Background="White"
        d:DataContext="{d:DesignInstance Type={x:Type local:DesignMainWindowViewModel}, IsDesignTimeCreatable=True}">
    <Window.Background>
        <ImageBrush/>
    </Window.Background>
    <StackPanel Margin="20">

        <Button Content="Load Items"
                Height="40"
                Command="{Binding LoadItemsCommand}" />

        <TextBlock Margin="0,10,0,10"
                   FontWeight="Bold"
                   Text="{Binding StatusMessage}" />

        <ListBox ItemsSource="{Binding Items}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Id}" />
                        <TextBlock Text=" - " />
                        <TextBlock Text="{Binding Name}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </StackPanel>
</Window>
